# Etsy API Configuration
# Get your API key from https://www.etsy.com/developers/your-apps
ETSY_API_KEY=your_etsy_api_key_here
ETSY_SHARED_SECRET=your_etsy_shared_secret_here

# Your Etsy Shop ID (numeric) or shop name
ETSY_SHOP_ID=your_shop_id_here

# OAuth redirect URI (default works for local development)
ETSY_REDIRECT_URI=http://localhost:3737/oauth/callback

# Local auth server port (default: 3737)
ETSY_AUTH_PORT=3737

# Data directory for tokens and history (default: ./data)
DATA_DIR=./data
